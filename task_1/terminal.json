      "content_lines": [
        "Requirements:",
        "  - Python 3.8 or higher",
        "  - pandas library",
        "",
        "Installation:",
        "  pip install pandas",
        "",
        "CSV File Format:",
        "  The input CSV file must contain the following columns:",
        "  - specie: name of the species",
        "  - location: GPS coordinates in format \"latitude,longitude\"",
        "  - status: conservation status (e.g., endangered, vulnerable, least_concern)",
        "  - param1: ecological distribution parameter 1 (float)",
        "  - param2: ecological distribution parameter 2 (float)",
        "  - param3: ecological distribution parameter 3 (float)",
        "",
        "Execution Steps:",
        "  1. Ensure your CSV file follows the format described above.",
        "  2. Run version 1 of the model:",
        "       python sdm_model_v1.py <path_to_your_csv_file>",
        "  3. Alternatively, run version 2 of the model:",
        "       python sdm_model_v2.py <path_to_your_csv_file>",
        "",
        "Example:",
        "  python sdm_model_v1.py test_amazon.csv"
      ],
